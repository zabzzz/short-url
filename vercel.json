{
    "buildCommand": "cd short && npm install && npm run build",
    "outputDirectory": "short/dist",
    "rewrites": [
      { "source": "/admin/:path*", "destination": "/api/index.js" },
      { "source": "/shorten", "destination": "/api/index.js" },
      { "source": "/:code", "destination": "/api/index.js" }
    ]
  }